{
  "rewrites": [
    {
      "source": "/app",
      "destination": "/app/index.html"
    },
    {
      "source": "/app/",
      "destination": "/app/index.html"
    },
    {
      "source": "/w",
      "destination": "/app/index.html"
    },
    {
      "source": "/w/",
      "destination": "/app/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
